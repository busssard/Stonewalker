#: accounts/utils.py:46
msgid "Restore password"
msgstr "Восстановить пароль"

#: accounts/templates/accounts/restore_password_confirm.html:13
msgid ""
"Please enter your new password twice so we can verify you typed it in "
"correctly."
msgstr ""
"Введите новый пароль дважды, чтобы мы могли убедиться, что вы ввели его "
"правильно."

#: accounts/templates/accounts/restore_password_confirm.html:21
#: content/templates/main/change_language.html:32
msgid "Change"
msgstr "Изменить"

#: accounts/templates/accounts/restore_password_confirm.html:28
msgid ""
"The password reset link was invalid, possibly because it has already been "
"used. Please request a new password reset."
msgstr ""
"Ссылка для сброса пароля недействительна, возможно, она уже была "
"использована. Запросите новый сброс пароля."

#: accounts/templates/accounts/restore_password_done.html:10
msgid ""
"We've emailed you instructions for setting your password, if an account "
"exists with the email you entered."
msgstr ""
"Мы отправили вам инструкции по установке пароля на почту, если учётная "
"запись с введённым email существует."

#: accounts/templates/accounts/restore_password_done.html:11
msgid "You should receive them shortly."
msgstr "Вы должны получить его в скором времени."

#: accounts/templates/accounts/restore_password_done.html:15
msgid ""
"If you don't receive an email, please make sure you've entered the address "
"you signed up with, and check your spam folder."
msgstr ""
"Если вы не получили письмо, убедитесь, что ввели адрес, с которым "
"регистрировались, и проверьте папку со спамом."

#: accounts/templates/accounts/sign_up.html:14
msgid "Create an account"
msgstr "Создать учётную запись"

#: accounts/templates/accounts/sign_up.html:15
msgid ""
"Join the journey! Track, share, and discover painted stones around the world."
msgstr ""
"Присоединяйтесь! Отслеживайте, делитесь и находите раскрашенные камни по "
"всему миру."

#: accounts/templates/accounts/sign_up.html:48
msgid "First name"
msgstr "Имя"

#: accounts/templates/accounts/sign_up.html:58
msgid "Last name"
msgstr "Фамилия"

#: accounts/templates/accounts/sign_up.html:89
msgid "Confirm password"
msgstr "Подтвердите пароль"

#: accounts/templates/accounts/sign_up.html:99
msgid "Create"
msgstr "Создать"

#: accounts/templates/accounts/sign_up.html:103
msgid "Already have an account?"
msgstr "Уже есть учётная запись?"

#: accounts/utils.py:28
msgid "Profile activation"
msgstr "Активация профиля"

#: accounts/utils.py:37
msgid "Change email"
msgstr "Изменить почту"

#: accounts/utils.py:56
msgid "Your username"
msgstr "Ваше имя пользователя"

#: accounts/views.py:143
msgid ""
"You are signed up. To activate the account, follow the link sent to the mail."
msgstr ""
"Вы зарегистрированы. Для активации аккаунта перейдите по ссылке в письме."

#: accounts/views.py:152 accounts/views.py:227 accounts/views.py:399
#: accounts/views.py:507
msgid "Failed to send activation email. Please try again or contact support."
msgstr ""
"Не удалось отправить письмо для активации. Попробуйте ещё раз или обратитесь "
"в поддержку."

#: accounts/views.py:160
msgid "You are successfully signed up!"
msgstr "Вы успешно создали учётную запись!"

#: accounts/views.py:186
msgid "You have successfully activated your account!"
msgstr "Вы успешно активировали свою учётную запись!"

#: accounts/views.py:223
msgid "A new activation code has been sent to your email address."
msgstr "Новый код активации отправлен на вашу электронную почту."

#: accounts/views.py:263
msgid "Your username has been successfully sent to your email."
msgstr "Ваше имя пользователя успешно отправлено на вашу почту."

#: accounts/views.py:275
msgid "Your password has been set. You may go ahead and log in now."
msgstr "Ваш пароль установлен. Теперь вы можете войти."

#: accounts/views.py:368
msgid ""
"You have reached the maximum number of email change attempts. Please try "
"again later."
msgstr ""
"Вы достигли максимального количества попыток изменения email. Попробуйте "
"позже."

#: accounts/views.py:393
msgid "To complete the change of email address, click on the link sent to it."
msgstr "Чтобы завершить смену email, нажмите на ссылку, отправленную на него."

#: accounts/views.py:405
msgid "Email successfully changed."
msgstr "Почта успешно изменена."

#: accounts/views.py:445
msgid "Your password was changed."
msgstr "Ваш пароль изменён."

#: accounts/views.py:447
msgid "Profile data has been successfully updated."
msgstr "Данные профиля были успешно обновлены."

#: accounts/views.py:473
msgid "You have successfully changed your email!"
msgstr "Вы успешно изменили свою почту!"

#: accounts/views.py:485
msgid "No pending email confirmation to resend."
