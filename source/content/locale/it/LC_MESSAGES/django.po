#: content/templates/main/checkout_success.html:76
msgid "Paint a stone, then attach the QR code with clear tape or varnish."
msgstr ""
"Dipingi una pietra, poi attacca il codice QR con nastro trasparente o "
"vernice."

#: content/templates/main/checkout_success.html:82
msgid "Hide"
msgstr "Nascondi"

