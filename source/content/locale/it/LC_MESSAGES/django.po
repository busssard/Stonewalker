#: content/templates/main/checkout_success.html:69
msgid "Download and print your QR code(s) on regular paper."
msgstr "Scarica e stampa i tuoi codici QR su carta normale."

#: content/templates/main/checkout_success.html:75
msgid "Paint & Attach"
